# Copy this file to .env and fill in your values
# NEVER commit .env to git

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/expense-tracker?retryWrites=true&w=majority
# JWT secret — use a long random string (e.g. openssl rand -base64 48)
JWT_SECRET=replace_with_a_long_random_secret

# Token expiry (e.g. 7d, 1d, 12h)
JWT_EXPIRES_IN=7d

# Port (Render sets this automatically; leave as 5000 for local dev)
PORT=5000

# Frontend origin for CORS (comma-separated if multiple)
# For local dev: http://localhost:3000
# For production: https://your-frontend.onrender.com
CLIENT_ORIGIN=http://localhost:3000
